@using FrontColegio.Services
@using FrontColegio.Models
@using Microsoft.AspNetCore.Components.Forms   👈 ESTA LÍNEA ES LA CLAVE
@page "/alumnos/editar/{id:int}"
@inject AlumnoService AlumnoService
@inject NavigationManager Navigation

<h3>Editar Alumno</h3>

@if (alumno == null)
{
<p><em>Cargando...</em></p>
}
else
{
    <EditForm Model="alumno" OnValidSubmit="ActualizarAlumno">
        <DataAnnotationsValidator />
        <ValidationSummary />

        <div class="mb-3">
            <label for="identificacion" class="form-label">Identificacion</label>
            <InputText id="identificacion" class="form-control" @bind-Value="alumno.Identificacion" />
        </div>
        <div class="mb-3">
            <label for="nombre" class="form-label">Nombre</label>
            <InputText id="nombre" class="form-control" @bind-Value="alumno.Nombre" />
        </div>
        <div class="mb-3">
            <label for="apellido" class="form-label">Apellido</label>
            <InputText id="apellido" class="form-control" @bind-Value="alumno.Apellido" />
        </div>
        <div class="mb-3">
            <label for="edad" class="form-label">Edad</label>
            <InputNumber id="edad" class="form-control" @bind-Value="alumno.Edad" />
        </div>

        <div class="mb-3">
            <label for="direccion" class="form-label">Direccion</label>
            <InputText id="direccion" class="form-control" @bind-Value="alumno.Direccion" />
        </div>

        <div class="mb-3">
            <label for="telefono" class="form-label">Telefono</label>
            <InputText id="telefono" class="form-control" @bind-Value="alumno.Telefono" />
        </div>

        <button type="submit" class="btn btn-success">Actualizar</button>
        <button type="button" class="btn btn-secondary" @onclick="Cancelar">Cancelar</button>
    </EditForm>
}

@code {
    [Parameter]
    public int Id { get; set; }

    private AlumnoDto? alumno;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            alumno = await AlumnoService.GetAlumnoAsync(Id);
            if (alumno == null)
                Navigation.NavigateTo("/alumnos");
        }
        catch
        {
            Navigation.NavigateTo("/alumnos");
        }
    }

    private async Task ActualizarAlumno()
    {
        try
        {
            var response = await AlumnoService.UpdateAlumnoAsync(Id, alumno!);
            if (response.IsSuccessStatusCode)
                Navigation.NavigateTo("/alumnos");
        }
        catch
        {
            // Manejar error (puedes mostrar un mensaje en la UI)
        }
    }


    private void Cancelar()
    {
        Navigation.NavigateTo("/alumnos");
    }
}