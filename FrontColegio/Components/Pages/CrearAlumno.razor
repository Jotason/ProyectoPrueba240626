@using FrontColegio.Services
@using FrontColegio.Models
@using Microsoft.AspNetCore.Components.Forms
@page "/alumnos/crear"
@inject AlumnoService AlumnoService
@inject NavigationManager Navigation

<h3>Nuevo Alumno</h3>

<EditForm Model="nuevoAlumno" OnValidSubmit="GuardarAlumno">
    <!-- Cambiado aquí -->
    <DataAnnotationsValidator />
    <ValidationSummary />

    <div class="mb-3">
        <label for="nombre" class="form-label">Nombre</label>
        <InputText id="nombre" class="form-control" @bind-Value="nuevoAlumno.Nombre" />
    </div>
    <div class="mb-3">
        <label for="apellido" class="form-label">Apellido</label>
        <InputText id="apellido" class="form-control" @bind-Value="nuevoAlumno.Apellido" />
    </div>

    <button type="submit" class="btn btn-success">Guardar</button>
    <button type="button" class="btn btn-secondary" @onclick="Cancelar">Cancelar</button>
</EditForm>

@code {
    private AlumnoDto nuevoAlumno = new();

    // Método renombrado a GuardarAlumno (no "CrearAlumno")
    private async Task GuardarAlumno()
    {
        try
        {
            var response = await AlumnoService.CreateAlumnoAsync(nuevoAlumno);
            if (response.IsSuccessStatusCode)
            {
                Navigation.NavigateTo("/alumnos");
            }
            else
            {
                // Manejar error (por ejemplo, mostrar un mensaje)
                // Puedes usar un campo para mostrar error en la UI
            }
        }
        catch (Exception )
        {
            // Manejar excepción
        }
    
    
    }

    private void Cancelar()
    {
        Navigation.NavigateTo("/alumnos");
    }
}