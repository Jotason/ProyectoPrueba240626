@page "/alumnos"
@using FrontColegio.Services
@using FrontColegio.Models
@using Microsoft.JSInterop
@inject NavigationManager Navigation
@inject AlumnoService AlumnoService
@inject IJSRuntime JsRuntime

<h3>Lista de Alumnos</h3>

<button class="btn btn-primary mb-3" @onclick="NuevoAlumno">Agregar Alumno</button>


@if (alumnos == null)
{
    <p><em>Cargando...</em></p>
}
else if (!alumnos.Any())
{
    <p>No hay alumnos registrados.</p>
}
else
{
    <table class="table table-striped">
        <thead>
            <tr>
                <th>ID</th>
                <th>Nombre</th>
                <th>Apellido</th>
                <th>Acciones</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var alumno in alumnos)
            {
                <tr>
                    <td>@alumno.Id</td>
                    <td>@alumno.Nombre</td>
                    <td>@alumno.Apellido</td>
                    <td>
                        <button class="btn btn-info btn-sm" @onclick="() => EditarAlumno(alumno.Id)">Editar</button>
                        <button class="btn btn-danger btn-sm" @onclick="() => EliminarAlumno(alumno.Id)">Eliminar</button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@if (!string.IsNullOrEmpty(mensajeError))
{
    <div class="alert alert-danger">@mensajeError</div>
}

@code {
    private List<AlumnoDto>? alumnos;
    private string? mensajeError;

    protected override async Task OnInitializedAsync()
    {
        await CargarAlumnos();
    }

    private async Task CargarAlumnos()
    {
        try
        {
            alumnos = await AlumnoService.GetAlumnosAsync();
            mensajeError = null;
        }
        catch (Exception ex)
        {
            mensajeError = $"Error al cargar alumnos: {ex.Message}";
        }
    }

    private void NuevoAlumno()
    {
        Console.WriteLine("Botón Agregar clickeado");
        Navigation.NavigateTo("/alumnos/crear");
    }
    private void EditarAlumno(int id)
    {
        Console.WriteLine($"Botón Editar clickeado para ID {id}");
        Navigation.NavigateTo($"/alumnos/editar/{id}");
    }


    private void TestClick()
    {
        Console.WriteLine("¡Botón de prueba funcionando!");
    }

    private async Task EliminarAlumno(int id)
    {
        var confirmado = await JsRuntime.InvokeAsync<bool>("confirm", "¿Está seguro de eliminar este alumno?");
        if (confirmado)
        {
            try
            {
                var response = await AlumnoService.DeleteAlumnoAsync(id);
                if (response.IsSuccessStatusCode)
                {
                    await CargarAlumnos();
                }
                else
                {
                    mensajeError = "Error al eliminar el alumno.";
                }
            }
            catch (Exception ex)
            {
                mensajeError = $"Error: {ex.Message}";
            }
        }
    }
}