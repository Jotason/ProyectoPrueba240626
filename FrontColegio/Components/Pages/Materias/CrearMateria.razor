@page "/materias/crear"
@using FrontColegio.Models
@using FrontColegio.Services
@using Microsoft.AspNetCore.Components.Forms
@inject MateriaService MateriaService
@inject ProfesorService ProfesorService
@inject NavigationManager Navigation

<h3>Nueva Materia</h3>

<EditForm Model="nuevaMateria" OnValidSubmit="GuardarMateria">
    <DataAnnotationsValidator />
    <ValidationSummary />

    <div class="mb-3">
        <label for="codigo" class="form-label">Código</label>
        <InputText id="codigo" class="form-control" @bind-Value="nuevaMateria.Codigo" />
    </div>
    <div class="mb-3">
        <label for="nombre" class="form-label">Nombre</label>
        <InputText id="nombre" class="form-control" @bind-Value="nuevaMateria.Nombre" />
    </div>
    <div class="mb-3">
        <label for="profesor" class="form-label">Profesor</label>
        <InputSelect id="profesor" class="form-select" @bind-Value="nuevaMateria.ProfesorId">
            <option value="">Seleccione un profesor...</option>
            @foreach (var profesor in profesores)
            {
                <option value="@profesor.Id">@profesor.Nombre @profesor.Apellido</option>
            }
        </InputSelect>
    </div>

    <button type="submit" class="btn btn-success">Guardar</button>
    <button type="button" class="btn btn-secondary" @onclick="Cancelar">Cancelar</button>
</EditForm>

@code {
    private MateriaDto nuevaMateria = new();
    private List<ProfesorDto>? profesores = new();

    protected override async Task OnInitializedAsync()
    {
        try
        {
            profesores = await ProfesorService.GetProfesorsAsync();
        }
        catch (Exception ex)
        {
            // Manejar error (mostrar mensaje en UI)
            Console.WriteLine($"Error al cargar profesores: {ex.Message}");
        }
    }

    private async Task GuardarMateria()
    {
        try
        {
            var response = await MateriaService.CreateMateriaAsync(nuevaMateria);
            if (response.IsSuccessStatusCode)
                Navigation.NavigateTo("/materias");
            else
            {
                // Mostrar error
                var error = await response.Content.ReadAsStringAsync();
                // Puedes asignar a una variable para mostrar en la UI
            }
        }
        catch (Exception ex)
        {
            // Manejar excepción
        }
    }

    private void Cancelar() => Navigation.NavigateTo("/materias");
}