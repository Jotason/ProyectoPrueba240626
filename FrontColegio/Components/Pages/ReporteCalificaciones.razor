@page "/reporte-calificaciones"
@using FrontColegio.Models
@using FrontColegio.Services
@inject ReporteService ReporteService

<h3>Reporte de Calificaciones</h3>

@if (reporte == null)
{
    <p><em>Cargando...</em></p>
}
else if (!reporte.Any())
{
    <p>No hay calificaciones registradas.</p>
}
else
{
    <div class="table-responsive">
        <table class="table table-striped table-bordered">
            <thead class="table-dark">
                <tr>
                    <th>Año académico</th>
                    <th>Identificación Alumno</th>
                    <th>Nombre Alumno</th>
                    <th>Código Materia</th>
                    <th>Nombre Materia</th>
                    <th>Identificación del profesor</th>
                    <th>Nombre del profesor</th>
                    <th>Calificación final</th>
                    <th>Aprobó</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in reporte)
                {
                    <tr>
                        <td>@item.AnioAcademico</td>
                        <td>@item.IdentificacionAlumno</td>
                        <td>@item.NombreAlumno</td>
                        <td>@item.CodigoMateria</td>
                        <td>@item.NombreMateria</td>
                        <td>@item.IdentificacionProfesor</td>
                        <td>@item.NombreProfesor</td>
                        <td>@item.CalificacionFinal.ToString("0.00")</td>
                        <td>
                            @if (item.Aprobo == "SI")
                            {
                                <span class="badge bg-success">SI</span>
                            }
                            else
                            {
                                <span class="badge bg-danger">NO</span>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@code {
    private List<ReporteCalificacionesDto>? reporte;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            reporte = await ReporteService.GetReporteCalificacionesAsync();
        }
        catch (Exception ex)
        {
            // Opcional: mostrar mensaje de error
            Console.WriteLine($"Error al cargar reporte: {ex.Message}");
        }
    }
}